# ── Dependencies ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Output ─────────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Environment Variables ────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ── Vite ─────────────────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ── Testing ──────────────────────────────────────────────────
coverage/
playwright-report/
test-results/
screenshots/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE & Editors ────────────────────────────────────────────
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# NOTE: .vscode/ is intentionally NOT ignored
# Keep .vscode/settings.json and .vscode/extensions.json for team consistency
# Only ignore personal/generated files:
.vscode/*.code-snippets

# ── Claude Code / Antigravity ────────────────────────────────
# Keep .claude/ committed — contains rules, skills, and commands for the agent
# Keep .agent/ committed — Antigravity skill mappings
# Only ignore generated/cached agent outputs:
.claude/cache/
.agent/cache/
.agents/

# ── Linting ──────────────────────────────────────────────────
.eslintcache
.stylelintcache

# ── Package Manager ──────────────────────────────────────────
.yarn/
.pnpm-store/

# ── Temporary Files ──────────────────────────────────────────
*.tmp
*.temp
.temp/
tmp/

# ── Media / Generated Assets ─────────────────────────────────
# Keep: src/assets/images/ (committed intentionally)
# Keep: public/ (all files needed for deployment)
# Ignore: auto-generated media outputs
media/output/
remotion/out/

# Auto-generated screenshots
docs/screenshots/
*.png
*.jpg
!public/og-image.jpg
!src/assets/**/*.jpg
!src/assets/**/*.png
